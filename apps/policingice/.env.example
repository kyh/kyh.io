# Copy to .env and fill in. `pnpm dev:policingice` loads it via dotenv-cli.

# Turso (libsql). REQUIRED — the app refuses to boot without it.
# There is no local database: this URL points at the live production Turso
# instance, so `db:push`, `db:studio` and everything in scripts/ hit production.
TURSO_DATABASE_URL="libsql://<database>-<org>.turso.io"
TURSO_AUTH_TOKEN=""

# better-auth signing secret (email+password / anonymous sessions).
BETTER_AUTH_SECRET=""

# Optional. Missing keys disable the feature instead of crashing boot:
# AI_GATEWAY_API_KEY — embeddings for semantic incident search + scripts/embed-incidents.ts
# XAI_API_KEY        — scripts/enrich-metadata.ts
AI_GATEWAY_API_KEY=""
XAI_API_KEY=""
