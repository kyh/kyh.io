{
  "name": "kyh",
  "version": "0.1.2",
  "description": "Personal CLI tool",
  "bin": {
    "kyh": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node' --packages=external",
    "dev": "tsx --watch src/index.tsx",
    "clean": "rm -rf dist node_modules",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
    "react": "catalog:"
  },
  "devDependencies": {
    "@kyh/tsconfig": "workspace:^",
    "@types/react": "catalog:",
    "esbuild": "^0.28.0",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
