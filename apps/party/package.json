{
  "name": "@repo/party",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir=dist",
    "clean": "rm -rf .turbo node_modules .cache .wrangler dist",
    "deploy": "wrangler deploy --name kyh-party",
    "dev": "pnpm with-env wrangler dev",
    "lint": "oxlint --report-unused-disable-directives",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@kyh/tsconfig": "workspace:^",
    "partyserver": "^0.5.8",
    "typescript": "catalog:",
    "wrangler": "^4.110.0"
  }
}
