{
  "name": "kyh-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean-workspaces": "turbo run clean",
    "db-supabase": "pnpm -F db supabase",
    "dev": "turbo watch dev --continue",
    "dev-cli": "pnpm -F kyh dev",
    "dev-stonksville": "pnpm -F @repo/stonksville dev",
    "dev-covid": "pnpm -F @repo/covid-19-dashboard dev",
    "dev-kwadrants": "pnpm -F @repo/kwadrants dev",
    "dev-policingice": "pnpm -F @repo/policingice dev",
    "dev-kyh": "pnpm -F @repo/kyh dev",
    "dev-party": "pnpm -F @repo/party dev",
    "dev-tc": "pnpm -F @repo/tc dev",
    "dev-vis-ml": "pnpm -F @repo/vis-ml dev",
    "deploy-party": "pnpm -F @repo/party deploy",
    "lint": "oxlint --report-unused-disable-directives",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "publish-packages": "changeset version && changeset publish",
    "format": "oxfmt",
    "lint-fix": "oxlint --fix",
    "format-fix": "oxfmt --write"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "dotenv-cli": "^11.0.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.57.0",
    "tsx": "catalog:",
    "turbo": "^2.8.21",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.0"
}
